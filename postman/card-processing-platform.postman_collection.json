                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{holderBaseUrl}}/api/v1/holders/{{holderId}}",
              "host": [
                "{{holderBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "holders",
                "{{holderId}}"
              ]
            }
          }
        },
        {
          "name": "Get Aggregated Holder View",
          "event": [
            {
              "listen": "test",
              "script": {
